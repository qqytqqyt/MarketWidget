{
  "name": "market-widget",
  "version": "1.0.0",
  "description": "Desktop widget for live share prices with after-hours and overnight sessions",
  "main": "main.js",
  "author": "qqytqqyt",
  "license": "MIT",
  "repository": "github:qqytqqyt/MarketWidget",
  "scripts": {
    "start": "electron .",
    "icon": "electron build/gen-icon.js",
    "dist": "electron-builder --win --publish never"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "io.github.qqytqqyt.marketwidget",
    "productName": "Market Widget",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "qqytqqyt",
      "repo": "MarketWidget",
      "releaseType": "release"
    }
  }
}
